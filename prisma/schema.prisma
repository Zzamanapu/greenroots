generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  VENDOR
  CUSTOMER
}

enum UserStatus {
  active
  suspended
  banned
}

enum CertStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  DELIVERED
  CANCELLED
}

model User {
  id            Int            @id @default(autoincrement())
  name          String
  email         String         @unique
  password      String
  role          Role           @default(CUSTOMER)
  status        UserStatus     @default(active)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  vendorProfile VendorProfile?
  orders        Order[]
  posts         CommunityPost[]
  plantLogs     PlantLog[]
}

model VendorProfile {
  id                  Int        @id @default(autoincrement())
  userId              Int        @unique
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  farmName            String
  farmLocation        String
  bio                 String?
  certificationStatus CertStatus @default(PENDING)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  produce             Produce[]
  rentalSpaces        RentalSpace[]
  orders              Order[]
  sustainabilityCerts SustainabilityCert[]
}

model Produce {
  id                  Int        @id @default(autoincrement())
  vendorId            Int
  vendor              VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  name                String
  description         String
  price               Float
  category            String
  certificationStatus CertStatus @default(PENDING)
  availableQuantity   Int        @default(0)
  imageUrl            String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  orders              Order[]
  plantLogs           PlantLog[]
}

model RentalSpace {
  id           Int           @id @default(autoincrement())
  vendorId     Int
  vendor       VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  location     String
  size         String
  pricePerMonth Float
  availability Boolean       @default(true)
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Order {
  id        Int         @id @default(autoincrement())
  userId    Int
  user      User        @relation(fields: [userId], references: [id])
  produceId Int
  produce   Produce     @relation(fields: [produceId], references: [id])
  vendorId  Int
  vendor    VendorProfile @relation(fields: [vendorId], references: [id])
  quantity  Int         @default(1)
  status    OrderStatus @default(PENDING)
  orderDate DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model CommunityPost {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  postContent String
  tags        String[]
  postDate    DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SustainabilityCert {
  id                Int           @id @default(autoincrement())
  vendorId          Int
  vendor            VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  certifyingAgency  String
  certificationDate DateTime
  expiryDate        DateTime?
  status            CertStatus    @default(PENDING)
  createdAt         DateTime      @default(now())
}

model PlantLog {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  produceId   Int
  produce     Produce  @relation(fields: [produceId], references: [id])
  stage       String   // seedling, growing, flowering, harvest-ready
  healthScore Int      @default(100) // 0-100
  notes       String?
  loggedAt    DateTime @default(now())
}
